# Apt — required environment variables
# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored and should never be committed.

# Card version for A/B testing (A, B, or C)
NEXT_PUBLIC_CARD_VERSION=C

# Voyage AI — semantic neighbourhood matching
# Sign up at https://dash.voyageai.com — free tier available
VOYAGE_API_KEY=

# Anthropic — Claude-generated personalised comparison text
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=
